+import block_names from "./html/html_blocks.js";
+const BLOCK_TAGS = new Set(block_names);
+/**
+ * HTML's content model rules say a block-level element implicitly closes any
+ * open `<p>` ancestor. When an author writes inline HTML like
+ *
+ *   <br><blockquote>...</blockquote>
+ *
+ * the leading inline `<br>` prevents markdown-it from classifying the line as
+ * a block, so the `<blockquote>` arrives nested inside the surrounding `<p>`
+ * paragraph. That produces structurally invalid HTML downstream.
+ *
+ * `liftBlockHtmlFromParagraphs` walks the tree and, when it finds a `<p>` whose
+ * inline children include a known block-level HTML element node (one tagged
+ * with `$.html` in its props), splits the paragraph at that point, lifting the
+ * block element to be a sibling of its (former) parent paragraph.
+ */
+export function liftBlockHtmlFromParagraphs(nodes) {
+    const out = [];
+    for (const node of nodes) {
+        if (typeof node === 'string') {
+            out.push(node);
+            continue;
+        }
+        if (!Array.isArray(node) || node.length < 2) {
+            out.push(node);
+            continue;
+        }
+        const [tag, props, ...children] = node;
+        const liftedChildren = liftBlockHtmlFromParagraphs(children);
+        if (tag !== 'p') {
+            out.push([tag, props, ...liftedChildren]);
+            continue;
+        }
+        // Scan paragraph children for embedded block-level HTML elements.
+        const splits = [];
+        let buffer = [];
+        for (const child of liftedChildren) {
+            if (isBlockHtmlElement(child)) {
+                if (buffer.length > 0) {
+                    splits.push([tag, props, ...buffer]);
+                    buffer = [];
+                }
+                splits.push(child);
+            }
+            else {
+                buffer.push(child);
+            }
+        }
+        if (splits.length === 0) {
+            out.push([tag, props, ...liftedChildren]);
+            continue;
+        }
+        if (buffer.length > 0) {
+            splits.push([tag, props, ...buffer]);
+        }
+        out.push(...splits);
+    }
+    return out;
+}
+function isBlockHtmlElement(node) {
+    if (typeof node === 'string' || !Array.isArray(node) || node.length < 2)
+        return false;
+    const [tag, props] = node;
+    if (typeof tag !== 'string')
+        return false;
+    if (!BLOCK_TAGS.has(tag))
+        return false;
+    // Only lift nodes that originated from raw HTML — markdown-produced block
+    // elements (which shouldn't appear inside <p> in the first place) are out of
+    // scope, and tagging by origin avoids surprising rewrites of authored AST.
+    const meta = props?.$;
+    return !!meta && meta.html === 1;
+}
