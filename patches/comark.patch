+import type { ComarkNode } from 'comark';
+/**
+ * HTML's content model rules say a block-level element implicitly closes any
+ * open `<p>` ancestor. When an author writes inline HTML like
+ *
+ *   <br><blockquote>...</blockquote>
+ *
+ * the leading inline `<br>` prevents markdown-it from classifying the line as
+ * a block, so the `<blockquote>` arrives nested inside the surrounding `<p>`
+ * paragraph. That produces structurally invalid HTML downstream.
+ *
+ * `liftBlockHtmlFromParagraphs` walks the tree and, when it finds a `<p>` whose
+ * inline children include a known block-level HTML element node (one tagged
+ * with `$.html` in its props), splits the paragraph at that point, lifting the
+ * block element to be a sibling of its (former) parent paragraph.
+ */
+export declare function liftBlockHtmlFromParagraphs(nodes: ComarkNode[]): ComarkNode[];
