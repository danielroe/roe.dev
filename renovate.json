{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":pinAllExceptPeerDependencies",
    "github>danielroe/renovate"
  ],
  "packageRules": [
    {
      "groupName": "unocss",
      "matchPackageNames": [
        "/unocss/"
      ]
    },
    {
      "groupName": "react",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ]
    }
  ]
}
