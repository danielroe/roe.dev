{
  "name": "roe.dev",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "pnpm rebuild sharp && nuxt build",
    "start": "nuxt start",
    "partykit:dev": "partykit dev ./partykit/server.ts",
    "partykit:deploy": "partykit deploy ./partykit/server.ts",
    "lint:js": "eslint .",
    "lint:style": "stylelint **/*.{vue,css} --fix --ignore-path .gitignore",
    "lint": "pnpm lint:js && pnpm lint:style",
    "test": "vitest run",
    "test:types": "nuxt prepare && vue-tsc -b --noEmit",
    "test:e2e": "playwright test test/e2e",
    "test:e2e:update": "docker run --rm --network host -v $(pwd):/work/ -v /tmp/playwright-nm:/work/node_modules -w /work/ -it mcr.microsoft.com/playwright:v1.60.0-noble bash -c 'corepack enable && pnpm i && pnpm playwright test test/e2e --update-snapshots'",
    "postinstall": "nuxt prepare && pnpm simple-git-hooks install",
    "auth:linkedin": "node --env-file=.env scripts/linkedin-auth.ts",
    "auth:youtube": "node --env-file=.env scripts/youtube-auth.ts",
    "auth:youtube:refresh": "node --env-file=.env scripts/youtube-auth.ts refresh",
    "lex:gen": "node scripts/gen-lex.mjs"
  },
  "nano-staged": {
    "*.{js,ts,mjs,vue}": [
      "eslint"
    ],
    "*.{css,vue}": "stylelint"
  },
  "dependencies": {
    "@atcute/bluesky-richtext-segmenter": "^3.0.0",
    "@atproto/api": "^0.19.18",
    "@atproto/lexicon": "^0.6.2",
    "@atproto/oauth-client-node": "0.4.1",
    "@formkit/drag-and-drop": "0.5.3",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "^1.1.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/html-validator": "2.1.0",
    "@nuxtjs/mdc": "0.22.0",
    "@nuxtjs/plausible": "3.0.2",
    "@takumi-rs/core": "^1.1.2",
    "@unhead/vue": "2.1.13",
    "@unocss/nuxt": "66.6.8",
    "@unocss/postcss": "66.6.8",
    "@unocss/reset": "66.6.8",
    "@vercel/blob": "^2.3.3",
    "citty": "^0.2.2",
    "defu": "^6.1.7",
    "exsolve": "^1.0.8",
    "feed": "^5.2.1",
    "gray-matter": "4.0.3",
    "gsap": "^3.15.0",
    "h3": "^1.15.11",
    "image-meta": "^0.2.2",
    "js-yaml": "^4.1.1",
    "knitwork": "^1.3.0",
    "magic-regexp": "0.11.0",
    "magic-string": "^0.30.21",
    "masto": "^7.11.1",
    "mediabunny": "^1.45.2",
    "mlly": "^1.8.2",
    "mocked-exports": "^0.1.1",
    "modern-screenshot": "^4.7.0",
    "multiformats": "14.0.0",
    "nuxt": "4.4.6",
    "nuxt-og-image": "6.5.0",
    "nuxt-security": "2.6.0",
    "partykit": "0.0.115",
    "partysocket": "^1.1.19",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.1",
    "postcss-nesting": "^14.0.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "scule": "^1.3.0",
    "std-env": "^4.1.0",
    "tinyglobby": "^0.2.16",
    "ufo": "^1.6.4",
    "unocss": "66.6.8",
    "unplugin": "^3.0.0",
    "vue": "3.5.34",
    "vue-router": "5.0.7"
  },
  "devDependencies": {
    "@atproto/common-web": "0.4.21",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@nuxt/test-utils": "4.0.3",
    "@playwright/test": "1.60.0",
    "@types/html-to-text": "9.0.4",
    "@types/js-yaml": "^4.0.9",
    "@vue/test-utils": "2.4.10",
    "eslint": "9.39.4",
    "googleapis": "171.4.0",
    "happy-dom": "20.9.0",
    "html-to-text": "10.0.0",
    "nano-staged": "1.0.2",
    "ofetch": "1.5.1",
    "playwright-core": "1.60.0",
    "rollup": "4.60.4",
    "simple-git-hooks": "2.13.1",
    "stylelint": "17.11.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6",
    "vue-tsc": "3.2.9"
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --edit $1",
    "pre-commit": "npx nano-staged"
  },
  "packageManager": "pnpm@11.1.2"
}
